{# rsce_themoreGrid.html5.twig #}


{% block content %}

{# Wrapper-Tag bestimmen (Fallback: div) #}
{% if container_tag is defined and container_tag %}
	{% set wrapper_tag = container_tag %}
{% else %}
	{% set wrapper_tag = 'div' %}
{% endif %}

{# Grid-Faktor Style #}
{% if gridFaktor is defined and gridFaktor != 1 and gridFaktor != '' %}
	<style>
		#grid_{{ id }} {
			--gridFaktor: {{ gridFaktor }};
		}
	</style>
{% endif %}



{% if individuellGrid is defined %}
	

	{% for gridSettings in individuellGrid %}

		{% set amountOfGaps = 0 %}
		{% set amountOfElements = 0 %}
		{% set gridTemplateColumns = '' %}

		{% set gridTemplate = gridSettings['gridTemplate']|split(' ')%}
		{% set amountOfElements = gridTemplate|length %}
		{% set amountOfGaps = gridTemplate|length - 1 %}
		
		{% for gridEntry in gridTemplate %}
			
			{% set gridTemplateColumns = gridTemplateColumns ~ 'calc( ' ~ gridEntry ~ ' - ( var(--grid-gap)*var(--gridFaktor) / ' ~ amountOfElements ~ ' * '~ amountOfGaps ~' ) ) ' %}
		
		{% endfor %}
	
		
	{% set hasMin = gridSettings.mediaQueryMin is defined and gridSettings.mediaQueryMin is not null %}
		{% set hasMax = gridSettings.mediaQueryMax is defined and gridSettings.mediaQueryMax is not null %}
		
		
		
		{% set hasMedia = hasMin or hasMax %}
		
		
		<style>
	
			{% if hasMedia %}
				@media screen 
				{% if hasMin %}and (min-width:{{ gridSettings['mediaQueryMin'] }}){% endif %} 
				{% if hasMax %}and (max-width:{{ gridSettings['mediaQueryMax'] }}){% endif %} {
			{% endif %}
			

			
		{% if gridTemplate[0] != "" %}
		
		
			#grid_{{ id }} {
				grid-template-columns: {{ gridTemplateColumns }};
			}
		{% endif %}
		{% if hasMedia %}
		}
		{% endif %}
		</style>
		
		
	{% endfor %}
	


{% endif %}

<{{ wrapper_tag }}
	id="grid_{{ id }}"
	class="grid {{ grid }} {{ gridTablet }} {{ gridSmartphone }} {{ class }}
		{% if placeContent is defined and placeContent %} gridPlaceContent_{{ placeContent }}{% endif %}
	"
	{% if cssID is defined %}{{ cssID|raw }}{% endif %}
>

{% endblock %}